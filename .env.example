# Bật phân tích AI thật (tùy chọn). Sao chép file này thành .env.local và điền key.
# Nếu để trống, app tự động dùng engine phân tích cục bộ (vẫn hoạt động đầy đủ).

# OpenAI API key — chỉ dùng ở phía server, không lộ ra client.
OPENAI_API_KEY=

# Model dùng cho phân tích (mặc định: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
