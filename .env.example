# Sao chép file này thành .env.local và điền giá trị.

# ---- Supabase (bắt buộc) ----
# Lấy từ Project Settings → API. Cả hai biến này lộ ra client (NEXT_PUBLIC_),
# nhưng anon key chỉ an toàn nhờ Row Level Security đã bật ở DB.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Phân tích AI thật (tùy chọn) ----
# Nếu để trống, app tự động dùng engine phân tích cục bộ (vẫn hoạt động đầy đủ).

# OpenAI API key — chỉ dùng ở phía server, không lộ ra client.
OPENAI_API_KEY=

# Model dùng cho phân tích (mặc định: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Số lượt phân tích AI tối đa mỗi user mỗi ngày (mặc định: 20).
AI_DAILY_LIMIT=20
